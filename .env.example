# === LLM Configuration ===
# Primary: DeepSeek (cheap, Chinese-optimized)
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Premium: Claude (higher quality, fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Which LLM to use for report synthesis: "deepseek" or "claude"
REPORT_LLM=deepseek

# === Search Configuration ===
# DuckDuckGo is free, no key needed
SEARCH_MAX_RESULTS=12

# Optional paid search for better reliability
SERPAPI_API_KEY=
BRAVE_SEARCH_API_KEY=
BING_API_KEY=                    # Bing Search API key (Azure)

# Chinese search providers (free, no API key needed)
ENABLE_BAIDU=true                # Baidu search (scraping)
ENABLE_CHINESE_OFFICIAL=true     # Chinese gov site search (site: queries)

# Default search backend: "duckduckgo", "serpapi", or "brave"
SEARCH_BACKEND=duckduckgo

# === Application ===
DATABASE_URL=sqlite+aiosqlite:///./data/reports.db
CACHE_TTL_HOURS=168
SEARCH_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO
